---
interface Props {
    title: string;
    description: string;
    prefecture: string;
    canonicalUrl: string;
    schemaJson: string;
    footerArea: string;
}
const { title, description, prefecture, canonicalUrl, schemaJson, footerArea } = Astro.props;

const prefs = [
    { key: 'osaka',    label: '大阪府',  href: '/deadning/osaka/' },
    { key: 'hyogo',    label: '兵庫県',  href: '/deadning/hyogo/' },
    { key: 'kyoto',    label: '京都府',  href: '/deadning/kyoto/' },
    { key: 'shiga',    label: '滋賀県',  href: '/deadning/shiga/' },
    { key: 'nara',     label: '奈良県',  href: '/deadning/nara/' },
    { key: 'wakayama', label: '和歌山県', href: '/deadning/wakayama/' },
];
---
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="jdE4YuGRtgXmCtv4S9XqO3VXkrNluzwQu97TkQUB0ZA" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/deadning/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <Fragment set:html={`<script type="application/ld+json">${schemaJson}</script>`} />
</head>
<body>
    <nav class="pref-nav" id="pref-nav">
        <div class="pref-nav-inner">
            <span class="pref-nav-label">📍 エリア選択：</span>
            <div class="pref-nav-links">
                {prefs.map(p => (
                    <a href={p.href} class={prefecture === p.key ? 'active' : ''}>{p.label}</a>
                ))}
            </div>
        </div>
    </nav>
    <div class="floating-cta" id="floatingCta">
        <a href="https://lin.ee/g4NPYZ3" target="_blank" class="btn-line" id="floating-line-btn">
            <i class="fab fa-line"></i> 【無料】LINE見積もり
        </a>
        <a href="tel:070-8428-0866" class="btn-tel" id="floating-tel-btn">
            <i class="fas fa-phone-alt"></i> 今すぐ電話
        </a>
    </div>
    <slot />
    <footer id="footer">
        <div class="footer-info">
            <p class="footer-name">車の出張パーツ取付 特急便</p>
            <p>対応エリア：{footerArea}</p>
            <p>TEL：<a href="tel:070-8428-0866">070-8428-0866</a></p>
            <p>営業時間：9:00〜19:00（不定休）</p>
        </div>
        <p class="footer-copy">&copy; 2026 車の出張パーツ取付 特急便. All Rights Reserved.</p>
    </footer>
    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
        const floatingCta = document.getElementById('floatingCta');
        window.addEventListener('scroll', () => {
            floatingCta.classList.toggle('show', window.scrollY > 300);
        });
    </script>
</body>
</html>
