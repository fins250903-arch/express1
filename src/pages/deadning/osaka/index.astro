---
import DeadningLayout from '../../../layouts/DeadningLayout.astro';

const schemaJson = "{\"@context\": \"https://schema.org\", \"@type\": \"Service\", \"name\": \"\\u5927\\u962a \\u683c\\u5b89\\u51fa\\u5f35\\u30c7\\u30c3\\u30c9\\u30cb\\u30f3\\u30b0\\uff06\\u30b9\\u30d4\\u30fc\\u30ab\\u30fc\\u53d6\\u4ed8\\u30bb\\u30c3\\u30c8\\u30d7\\u30e9\\u30f3\", \"provider\": {\"@type\": \"LocalBusiness\", \"name\": \"\\u8eca\\u306e\\u51fa\\u5f35\\u30d1\\u30fc\\u30c4\\u53d6\\u4ed8 \\u7279\\u6025\\u4fbf\", \"description\": \"\\u5927\\u962a\\u30fb\\u5175\\u5eab\\u30fb\\u4eac\\u90fd\\u30fb\\u6ecb\\u8cc0\\u30fb\\u5948\\u826f\\u30fb\\u548c\\u6b4c\\u5c71\\u5bfe\\u5fdc\\u3002\\u6750\\u6599\\u6301\\u3061\\u8fbc\\u307f\\u6b53\\u8fce\\u306e\\u8eca\\u30c7\\u30c3\\u30c9\\u30cb\\u30f3\\u30b0\\u51fa\\u5f35\\u65bd\\u5de5\\u30b5\\u30fc\\u30d3\\u30b9\\u3002\", \"telephone\": \"070-8428-0866\", \"address\": {\"@type\": \"PostalAddress\", \"addressRegion\": \"\\u5927\\u962a\\u5e9c\"}}, \"areaServed\": [{\"@type\": \"State\", \"name\": \"\\u5927\\u962a\\u5e9c\"}, {\"@type\": \"State\", \"name\": \"\\u5175\\u5eab\\u770c\"}, {\"@type\": \"State\", \"name\": \"\\u4eac\\u90fd\\u5e9c\"}, {\"@type\": \"State\", \"name\": \"\\u6ecb\\u8cc0\\u770c\"}, {\"@type\": \"State\", \"name\": \"\\u5948\\u826f\\u770c\"}, {\"@type\": \"State\", \"name\": \"\\u548c\\u6b4c\\u5c71\\u770c\"}], \"hasOfferCatalog\": {\"@type\": \"OfferCatalog\", \"name\": \"\\u51fa\\u5f35\\u65bd\\u5de5\\u30e1\\u30cb\\u30e5\\u30fc\", \"itemListElement\": [{\"@type\": \"Offer\", \"itemOffered\": {\"@type\": \"Service\", \"name\": \"\\u30b9\\u30d4\\u30fc\\u30ab\\u30fc\\u4ea4\\u63db\\uff0b\\u30c7\\u30c3\\u30c9\\u30cb\\u30f3\\u30b0\\u540c\\u6642\\u65bd\\u5de5\\u30bb\\u30c3\\u30c8\", \"description\": \"\\u6750\\u6599\\u6301\\u3061\\u8fbc\\u307fOK\\u3002\\u30d5\\u30ed\\u30f3\\u30c8\\u30c9\\u30a22\\u679a\\u306e\\u30bb\\u30c3\\u30c8\\u5de5\\u8cc3\\u3002\\u7d042\\u301c3\\u6642\\u9593\\u3067\\u5b8c\\u4e86\\u3002\"}, \"price\": \"25000\", \"priceCurrency\": \"JPY\"}]}}";
---
<DeadningLayout
    title="大阪のデッドニング＆スピーカー取付出張サービス【特急便】材料持込OK・25,000円〜"
    description="大阪でAmazon・楽天で買ったスピーカーの取付＋デッドニングを出張施工。材料持込大歓迎！フロントドア2枚セット工賃25,000円〜。ご自宅の駐車場で完結。専門店より圧倒的に安い！"
    prefecture="osaka"
    canonicalUrl="https://abura.site/deadning/osaka/"
    schemaJson={schemaJson}
    footerArea="大阪府全域（兵庫・京都・滋賀・奈良・和歌山も対応）"
>


    <!-- ============================================ -->
    <!-- STEP 1: ファーストビュー -->
    <!-- ============================================ -->
    <header class="fv-section" id="fv">
        <div class="fv-sound-wave">
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="fv-badges">
            <span class="badge"><i class="fas fa-map-marker-alt"></i> 大阪府全域対応</span>
            <span class="badge"><i class="fas fa-box-open"></i> 材料持込完全無料</span>
            <span class="badge"><i class="fas fa-shield-alt"></i> 追加料金ゼロ宣言</span>
        </div>
        <h1 class="fv-catch">
            Amazonで買ったその<br>
            <span class="highlight-gold">スピーカー</span>、私が<br>
            <span class="highlight-red">最高の音</span>で取り付けます！
        </h1>
        <p class="fv-sub">
            <strong class="text-gold">大阪</strong>全域・出張デッドニング＆スピーカー取付<br>
            ご自宅の駐車場で完結。専門店より<strong class="text-gold">圧倒的に安い！</strong>
        </p>
        <div class="container">
            <!-- FVポイントリスト -->
            <ul class="fv-points">
                <li><i class="fas fa-check-circle"></i> <span><strong>材料持ち込み：完全無料・大歓迎！</strong>Amazon・楽天・ヤフオク品もOK</span></li>
                <li><i class="fas fa-check-circle"></i> <span><strong>出張施工：</strong>ご自宅の駐車場で全作業完結</span></li>
                <li><i class="fas fa-check-circle"></i> <span><strong>約2〜3時間で完了：</strong>待ち時間なし、あなたは家でくつろぐだけ</span></li>
            </ul>
            <!-- FV内CTA -->
            <div class="fv-cta">
                <a href="https://lin.ee/g4NPYZ3" target="_blank" class="btn-cta-primary pulse" id="fv-line-btn">
                    <i class="fab fa-line"></i> 今すぐ無料で見積もりする
                </a>
                <p class="cta-micro">※ 30分で完了・しつこい営業は一切しません</p>
            </div>
        </div>
    </header>

    <!-- ============================================ -->
    <!-- STEP 2: 共感・問題提起 -->
    <!-- ============================================ -->
    <section class="empathy-section" id="empathy">
        <div class="container">
            <h2 class="section-title">「いい音でドライブしたい。でも…」<br><span class="text-red">こんなお悩み、ありませんか？</span></h2>
            <ul class="problem-list fade-in">
                <li><i class="fas fa-sad-cry"></i> 専門店で見積もったら<strong>10万円を超えた…</strong></li>
                <li><i class="fas fa-tools"></i> 自分でやろうとドアを外しかけたが、<strong>元に戻せるか不安…</strong></li>
                <li><i class="fas fa-ban"></i> 格安店は<strong>「持ち込み不可」ばかりでガッカリ…</strong></li>
                <li><i class="fas fa-clock"></i> 平日は忙しく<strong>車を預けに行く時間がない…</strong></li>
                <li><i class="fas fa-question-circle"></i> デッドニングって<strong>本当に効果があるの？</strong></li>
            </ul>
            <div class="insight-box fade-in">
                <div class="insight-icon"><i class="fas fa-lightbulb"></i></div>
                <p class="insight-title">その悩み、特急便がすべて解決します！</p>
                <p class="insight-text">
                    デッドニングは、スピーカー交換と<strong>同時にやるのが「一番安くて一番効く」</strong>んです。<br>
                    セットで依頼すればコスト大幅カット。施工後は「え、こんなに変わるの？」と<br>
                    驚かれるお客様が<strong>大阪で続出中！</strong>
                </p>
            </div>
        </div>
    </section>


    <!-- ============================================ -->
    <!-- STEP 3: 解決策の提示 -->
    <!-- ============================================ -->
    <section class="solution-section" id="solution">
        <div class="container">
            <div class="solution-card fade-in">
                <h2 class="solution-catch">
                    そのお悩み、すべて<br>
                    <span class="big-text">「特急便」</span>が解決！
                </h2>
                <div class="solution-points">
                    <div class="solution-point">
                        <div class="solution-icon"><i class="fas fa-box-open"></i></div>
                        <p><strong>材料持ち込みへのこだわり</strong><br>ネットの安売り材料、中古パーツもOK。あなたが選んだこだわりの品を大切に扱います。</p>
                    </div>
                    <div class="solution-point">
                        <div class="solution-icon"><i class="fas fa-star"></i></div>
                        <p><strong>プロの指先</strong><br>マッチングサイトで高評価を量産中。配線のビビリ音対策まで、目に見えない場所も手を抜きません。</p>
                    </div>
                    <div class="solution-point">
                        <div class="solution-icon"><i class="fas fa-file-invoice-dollar"></i></div>
                        <p><strong>明朗会計</strong><br>当日の追加料金なし。出張料も事前に提示します。見積もり金額＝お支払い金額です。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- STEP 4: 選ばれる理由 -->
    <!-- ============================================ -->
    <section class="reasons-section" id="reasons">
        <div class="container">
            <h2 class="section-title">大阪で特急便が選ばれる<br><span class="text-red">6つの理由</span></h2>
            <div class="reasons-grid fade-in">
                <div class="reason-card">
                    <div class="reason-number">01</div>
                    <div class="reason-icon"><i class="fas fa-tag"></i></div>
                    <h3>圧倒的な低価格</h3>
                    <p>店舗を持たない出張専門だから、家賃も中間マージンもゼロ。</p>
                </div>
                <div class="reason-card">
                    <div class="reason-number">02</div>
                    <div class="reason-icon"><i class="fas fa-file-invoice-dollar"></i></div>
                    <h3>追加料金なしの明朗会計</h3>
                    <p>見積もり後の追加請求は一切なし。安心のお約束です。</p>
                </div>
                <div class="reason-card">
                    <div class="reason-number">03</div>
                    <div class="reason-icon"><i class="fas fa-truck"></i></div>
                    <h3>大阪全域に出張</h3>
                    <p>ご自宅の駐車場で作業完了。店舗への往復の手間がゼロ。</p>
                </div>
                <div class="reason-card">
                    <div class="reason-number">04</div>
                    <div class="reason-icon"><i class="fas fa-tools"></i></div>
                    <h3>プロの確かな技術力</h3>
                    <p>多くの実績を持つ技術者が丁寧に施工。「安い＝手抜き」は絶対にありません。</p>
                </div>
                <div class="reason-card">
                    <div class="reason-number">05</div>
                    <div class="reason-icon"><i class="fas fa-box-open"></i></div>
                    <h3>どこで買ってもOK</h3>
                    <p>Amazon・楽天・ヤフオク・中古品。あなたの選んだパーツをプロが取付。</p>
                </div>
                <div class="reason-card">
                    <div class="reason-number">06</div>
                    <div class="reason-icon"><i class="fab fa-line"></i></div>
                    <h3>LINEで簡単見積もり</h3>
                    <p>車種とパーツURLを送るだけ。最短30分でお見積もりをお返しします。</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- STEP 5: ご利用の流れ -->
    <!-- ============================================ -->
    <section class="flow-section" id="flow">
        <div class="container">
            <h2 class="section-title">ご利用の流れ</h2>
            <div class="flow-steps fade-in">
                <div class="step">
                    <div class="step-num">STEP 1</div>
                    <div class="step-title">LINEで無料見積もり</div>
                    <p>車種とスピーカーのURL（またはパーツ名）をLINEで送るだけ！最短30分でお見積もりをお返しします。</p>
                </div>
                <div class="arrow"><i class="fas fa-chevron-down"></i></div>
                <div class="step">
                    <div class="step-num">STEP 2</div>
                    <div class="step-title">日程調整</div>
                    <p>お見積もりにご納得いただけたら、ご都合のいい日時を調整します。最短翌日OK！</p>
                </div>
                <div class="arrow"><i class="fas fa-chevron-down"></i></div>
                <div class="step">
                    <div class="step-num">STEP 3</div>
                    <div class="step-title">大阪のご自宅で出張施工</div>
                    <p>ご指定の場所（ご自宅の駐車場など）にお伺い。約2〜3時間作業。あなたは家でくつろいでいるだけでOK！</p>
                </div>
                <div class="arrow"><i class="fas fa-chevron-down"></i></div>
                <div class="step">
                    <div class="step-num">STEP 4</div>
                    <div class="step-title">試聴・作業完了・お支払い</div>
                    <p>音の確認後にお支払い。見積もり通りの明朗会計で安心です。感動の音質を体感してください！</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- STEP 6: お客様の声 -->
    <!-- ============================================ -->
    <section class="voice-section" id="voice">
        <div class="container">
            <h2 class="section-title">大阪のお客様の声</h2>
            <img src="/images/customer_happy.png" alt="施工に満足したお客様" class="voice-main-image fade-in">
            <div class="voice-cards fade-in">
                <div class="voice-card">
                    <div class="voice-header">
                        <div class="voice-stars">★★★★★</div>
                        <span class="voice-label">大阪市淀川区 T.K様（30代）</span>
                    </div>
                    <p class="voice-text">
                        「Amazonで買ったスピーカー、カー用品店に持ち込んだらデッドニングと合わせて8万円と言われてビックリ。特急便さんはセットで25,000円！<strong>施工後の音は本当に感動レベルで、前の音には戻れません。</strong>」
                    </p>
                </div>
                <div class="voice-card">
                    <div class="voice-header">
                        <div class="voice-stars">★★★★★</div>
                        <span class="voice-label">堺市 M.S様（40代）</span>
                    </div>
                    <p class="voice-text">
                        「最初は高いと感じましたが、特急便で大正解！<strong>ご自宅の駐車場で作業してもらい、待ち時間ゼロ。</strong>仕上がりも完璧で、妻にも『いい業者さん見つけたね』と褒められました（笑）」
                    </p>
                </div>
                <div class="voice-card">
                    <div class="voice-header">
                        <div class="voice-stars">★★★★★</div>
                        <span class="voice-label">豊中市 A.N様（50代）</span>
                    </div>
                    <p class="voice-text">
                        「DIYに挑戦しようとしたけど断念。特急便さんに頼んだら<strong>丁寧な施工で、ビビリ音も完全になくなりました。</strong>スピーカーの音が全然違う！次はリアドアもお願いします。」
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- 中間CTA -->
    <!-- ============================================ -->
    <section class="mid-cta-section" id="mid-cta">
        <div class="container">
            <h2 class="mid-cta-catch">「結局いくら？」と思ったら、<br>まずはLINEで無料見積もり！</h2>
            <p class="mid-cta-text">「このスピーカーなんだけど、工賃いくら？」──そんなご質問だけでも大歓迎です。</p>
            <div class="mid-cta-buttons">
                <a href="https://lin.ee/g4NPYZ3" target="_blank" class="btn-cta-primary pulse" id="mid-line-btn">
                    <i class="fab fa-line"></i> LINEで無料見積もり・相談
                </a>
                <a href="tel:070-8428-0866" class="btn-cta-secondary" id="mid-tel-btn">
                    <i class="fas fa-phone-alt"></i> 070-8428-0866<br><small>お急ぎの方はお電話で</small>
                </a>
            </div>
            <p class="cta-micro" style="color:rgba(255,255,255,0.6)">※ しつこい営業は一切しません。お気軽にどうぞ！</p>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- STEP 7: 料金表 -->
    <!-- ============================================ -->
    <section class="pricing-section" id="pricing">
        <div class="container">
            <h2 class="section-title">主要メニューと料金（税込）</h2>
            <div class="fade-in">
                <table class="price-table">
                    <thead>
                        <tr>
                            <th>メニュー</th>
                            <th style="text-align:right">工賃（税込）</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>🏆 <strong>フロントドア デッドニング＋スピーカー交換セット</strong><br><small>フロント左右2枚・材料持込OK</small></td>
                            <td class="price-highlight" style="text-align:right">25,000円〜</td>
                        </tr>
                        <tr>
                            <td>スピーカー交換のみ（フロント左右）<br><small>材料持込OK</small></td>
                            <td class="price-highlight" style="text-align:right">12,000円〜</td>
                        </tr>
                        <tr>
                            <td>デッドニングのみ（フロントドア左右）<br><small>制振材・吸音材持込OK</small></td>
                            <td class="price-highlight" style="text-align:right">15,000円〜</td>
                        </tr>
                        <tr>
                            <td>リアドア デッドニング＋スピーカー交換セット<br><small>材料持込OK</small></td>
                            <td class="price-highlight" style="text-align:right">20,000円〜</td>
                        </tr>
                    </tbody>
                </table>
                <div class="price-note-box">
                    ✅ 材料持ち込み完全無料<br>
                    ✅ 出張費は見積もりに含まれます（大阪府全域）<br>
                    ✅ 当日追加料金なし。見積もり金額＝お支払い金額<br>
                    ✅ Amazon・楽天・ヤフオク・中古品すべてOK
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- STEP 8: セットプランの魅力 -->
    <!-- ============================================ -->
    <section class="service-section" id="service">
        <div class="container">
            <h2 class="section-title">一番人気！<br><span class="text-gold">「音質劇的向上セットプラン」</span></h2>
            <div class="set-plan-card fade-in">
                <div class="set-plan-header">
                    <span class="set-plan-badge">🏆 大阪No.1人気</span>
                    <h3>フロントドア デッドニング＋スピーカー交換セット</h3>
                </div>
                <div class="set-plan-body">
                    <div class="set-plan-price">
                        <div class="price-num">25,000<span>円〜（税込）</span></div>
                        <p class="price-note">専門店の相場 70,000〜120,000円と比較してください</p>
                    </div>
                    <ul class="set-plan-items">
                        <li><i class="fas fa-check-circle"></i> <span><strong>フロントドア左右デッドニング</strong>（制振材・吸音材施工）</span></li>
                        <li><i class="fas fa-check-circle"></i> <span><strong>スピーカー交換</strong>（お持ち込み品取付）</span></li>
                        <li><i class="fas fa-clock"></i> <span>所要時間：<strong>約2〜3時間</strong>で完了</span></li>
                        <li><i class="fas fa-home"></i> <span>施工場所：<strong>ご自宅の駐車場</strong>でOK（大阪府全域出張）</span></li>
                    </ul>
                    <p class="plan-pr">「え、こんなに変わるの？」と、施工直後に驚かれるお客様が続出しています。</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================ -->
    <!-- STEP 9: FAQ -->
    <!-- ============================================ -->
    <section class="faq-section" id="faq">
        <div class="container">
            <h2 class="section-title">よくある質問</h2>
            <div class="faq-list fade-in">
                <div class="faq-item">
                    <div class="faq-q"><span>Q</span> デッドニングって本当に効果がありますか？</div>
                    <div class="faq-a"><span>A</span> 絶大な効果があります。ドア内部の振動を抑えることで、スピーカーの音がクリアになり、ロードノイズも大幅に減少します。施工直後に「こんなに違うの？」と驚かれるお客様が続出しています。</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q"><span>Q</span> Amazon・楽天で買ったスピーカーでも大丈夫ですか？</div>
                    <div class="faq-a"><span>A</span> もちろんです！材料持ち込みは完全無料・大歓迎です。ヤフオクや中古の品、前の車からの付け替えもOKです。ご購入前のご相談も承ります。</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q"><span>Q</span> マンションの駐車場でも作業可能ですか？</div>
                    <div class="faq-a"><span>A</span> はい、可能です。通常の乗り降りができるスペースがあれば問題ありません。大阪市内のマンション駐車場での施工実績も多数あります。事前写真をいただければより正確にお答えできます。</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q"><span>Q</span> 追加料金は本当にかかりませんか？</div>
                    <div class="faq-a"><span>A</span> 事前のお見積もり金額から、当日に追加料金を請求することは一切ございません。万が一追加作業が必要になった場合も、必ず事前にご了承をいただいてから進めます。</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q"><span>Q</span> 大阪のどのエリアまで対応しますか？</div>
